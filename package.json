{
	"name": "minimal-llm-chat",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./style.css": "./dist/index.css"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "biome check . && tsc --noEmit",
		"dev": "esbuild example/app.ts --bundle --outfile=example/bundle.js --servedir=example",
		"clean": "rm -rf dist",
		"build:lib": "npm run clean && tsc && npm run copy:css",
		"copy:css": "node scripts/copy-css.js",
		"test": "node --import tsx --test src/**/*.test.ts",
		"build:example": "esbuild example/app.ts --bundle --outfile=example/index.js --minify --target=es2017"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^25.6.0",
		"@types/prismjs": "^1.26.6",
		"esbuild": "^0.27.4",
		"jsdom": "^29.0.1",
		"prismjs": "^1.30.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"marked": "^17.0.5"
	}
}
