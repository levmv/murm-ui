{
	"files": {
		"includes": [
			"**",
			"!!**/dist",
			"!!docs/dist",
			"!!docs/demo/bundle.css",
			"!!docs/demo/bundle.js",
			"!!example/bundle.css",
			"!!example/bundle.js",
			"!!example/index.css",
			"!!example/index.js"
		]
	},
	"linter": {
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useButtonType": "off"
			},
			"style": {
				"useTemplate": "off",
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120
	}
}
