{
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"linter": {
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useButtonType": "off"
			},
			"style": {
				"useTemplate": "off",
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120
	}
}
